{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 4: Renaming the image and annotation files\n",
    "\n",
    "This Jupyter notebook renames the selected image tiles and their corresponding annotation files to sequential numbering. The script matches `.tif`, `.tfw`, and `.xml` files based on their original filename.\n",
    "\n",
    "The script was written for a project commissioned by the Municipality of Wageningen in relation to the course Remote Sensing and GIS Integration (GRS60312).\n",
    "\n",
    "The authors of the script are Polly Cheung, Pascal Dubbelman, Anthony Jansen, Iris Lagemaat, and Susanna van de Wetering.\n",
    "\n",
    "Last edited: 17/06/2026\n",
    "\n",
    "Before starting the script it is important that the image files (`.tif` and `.tfw`) are stored in one folder and the corresponding annotation files (`.xml`) are stored in a separate folder."
   ]
  },

  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Install packages\n",
    "import os\n",
    "import shutil\n",
    "import xml.etree.ElementTree as ET\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "\n",
    "# Set up\n",
    "\n",
    "# Folder containing the .tif and .tfw files\n",
    "IMAGE_FOLDER = r\"Path_to_your_image_folder\"\n",
    "\n",
    "# Folder containing the .xml annotation files\n",
    "XML_FOLDER = r\"Path_to_your_xml_folder\"\n",
    "\n",
    "# Output folders\n",
    "OUTPUT_IMAGE_FOLDER = r\"Path_to_your_image_output_folder\"\n",
    "OUTPUT_XML_FOLDER = r\"Path_to_your_xml_output_folder\"\n",
    "\n",
    "# Starting number\n",
    "START_NUMBER = 1\n",
    "\n",
    "# Sort order before numbering\n",
    "# 'name' sorts files alphabetically\n",
    "# 'mtime' sorts files by modification time\n",
    "SORT_BY = \"name\"\n",
    "\n",
    "# Preview mode\n",
    "# True = preview only, no files changed\n",
    "# False = rename or copy the files\n",
    "DRY_RUN = False"
   ]
  },

  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 1: Check whether the image files and annotation files are correctly matched.\n",
    "\n",
    "image_folder = Path(IMAGE_FOLDER)\n",
    "xml_folder = Path(XML_FOLDER)\n",
    "output_image_folder = Path(OUTPUT_IMAGE_FOLDER)\n",
    "output_xml_folder = Path(OUTPUT_XML_FOLDER)\n",
    "\n",
    "IMAGE_EXTS = {\".tif\", \".tfw\"}\n",
    "XML_EXT = \".xml\"\n",
    "\n",
    "for folder in [image_folder, xml_folder]:\n",
    "    if not folder.exists():\n",
    "        raise FileNotFoundError(f\"Folder not found: {folder}\")\n",
    "\n",
    "if not DRY_RUN:\n",
    "    output_image_folder.mkdir(parents=True, exist_ok=True)\n",
    "    output_xml_folder.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Collect the image files\n",
    "image_stems = defaultdict(dict)\n",
    "for f in image_folder.iterdir():\n",
    "    if f.suffix.lower() in IMAGE_EXTS:\n",
    "        image_stems[f.stem][f.suffix.lower()] = f\n",
    "\n",
    "# Collect the annotation files\n",
    "xml_stems = {}\n",
    "for f in xml_folder.iterdir():\n",
    "    if f.suffix.lower() == XML_EXT:\n",
    "        xml_stems[f.stem] = f\n",
    "\n",
    "# Find matching filenames\n",
    "all_stems = sorted(set(image_stems.keys()) | set(xml_stems.keys()))\n",
    "matched = [s for s in all_stems if s in image_stems and s in xml_stems]\n",
    "img_only = [s for s in all_stems if s in image_stems and s not in xml_stems]\n",
    "xml_only = [s for s in all_stems if s in xml_stems and s not in image_stems]\n",
    "\n",
    "print(f\"Matched stems: {len(matched)}\")\n",
    "print(f\"Image only: {len(img_only)}\")\n",
    "print(f\"XML only: {len(xml_only)}\")"
   ]
  },

  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 2: Create a renaming plan for the image and annotation files.\n",
    "\n",
    "plan = []\n",
    "\n",
    "for i, stem in enumerate(matched):\n",
    "    new_stem = str(START_NUMBER + i)\n",
    "    group = []\n",
    "\n",
    "    # Rename image files\n",
    "    for ext, old_path in sorted(image_stems[stem].items()):\n",
    "        new_path = output_image_folder / f\"{new_stem}{ext}\"\n",
    "        group.append({\"old\": old_path, \"new\": new_path, \"type\": \"image\"})\n",
    "\n",
    "    # Rename annotation file\n",
    "    old_xml = xml_stems[stem]\n",
    "    new_xml = output_xml_folder / f\"{new_stem}.xml\"\n",
    "    new_tif = f\"{new_stem}.tif\"\n",
    "\n",
    "    group.append({\"old\": old_xml, \"new\": new_xml, \"type\": \"xml\", \"new_tif\": new_tif})\n",
    "\n",
    "    plan.append(group)\n",
    "\n",
    "# Show a preview of the new filenames\n",
    "print(f\"{'OLD':<50} → NEW\")\n",
    "print(\"-\" * 75)\n",
    "\n",
    "for group in plan:\n",
    "    for item in group:\n",
    "        print(f\"{item['old'].name:<50} → {item['new'].name}\")\n",
    "    print()\n",
    "\n",
    "# Check for duplicate filenames\n",
    "all_new = [str(item['new']) for group in plan for item in group]\n",
    "\n",
    "if len(all_new) != len(set(all_new)):\n",
    "    print(\"Duplicate output names detected.\")\n",
    "else:\n",
    "    print(f\"{len(plan)} groups are ready to be renamed.\")"
   ]
  },

  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 3: Rename the files and update the XML information.\n",
    "\n",
    "if DRY_RUN:\n",
    "    print(\"Preview mode enabled. No files were changed.\")\n",
    "\n",
    "else:\n",
    "    renamed = 0\n",
    "    errors = []\n",
    "\n",
    "    for group in plan:\n",
    "        for item in group:\n",
    "\n",
    "            try:\n",
    "                old_path = item['old']\n",
    "                new_path = item['new']\n",
    "\n",
    "                if item['type'] == 'xml':\n",
    "\n",
    "                    # Update the filename and path stored in the XML file\n",
    "                    tree = ET.parse(old_path)\n",
    "                    root = tree.getroot()\n",
    "\n",
    "                    fn = root.find('filename')\n",
    "                    if fn is not None:\n",
    "                        fn.text = item['new_tif']\n",
    "\n",
    "                    pth = root.find('path')\n",
    "                    if pth is not None:\n",
    "                        pth.text = str(output_image_folder / item['new_tif'])\n",
    "\n",
    "                    tree.write(new_path, encoding='utf-8', xml_declaration=True)\n",
    "\n",
    "                else:\n",
    "                    shutil.copy2(old_path, new_path)\n",
    "\n",
    "                renamed += 1\n",
    "\n",
    "            except Exception as e:\n",
    "                errors.append((item['old'], str(e)))\n",
    "\n",
    "    print(f\"{renamed} files were renamed.\")"
   ]
  },

  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 4: Verify that each image has a corresponding annotation file.\n",
    "\n",
    "if not DRY_RUN:\n",
    "\n",
    "    img_out_stems = defaultdict(set)\n",
    "\n",
    "    for f in output_image_folder.iterdir():\n",
    "        if f.suffix.lower() in IMAGE_EXTS:\n",
    "            img_out_stems[f.stem].add(f.suffix.lower())\n",
    "\n",
    "    xml_out_stems = {\n",
    "        f.stem\n",
    "        for f in output_xml_folder.iterdir()\n",
    "        if f.suffix.lower() == XML_EXT\n",
    "    }\n",
    "\n",
    "    issues = []\n",
    "\n",
    "    for stem in sorted(set(img_out_stems) | xml_out_stems):\n",
    "\n",
    "        has_tif = '.tif' in img_out_stems.get(stem, set())\n",
    "        has_tfw = '.tfw' in img_out_stems.get(stem, set())\n",
    "        has_xml = stem in xml_out_stems\n",
    "\n",
    "        if not (has_tif and has_tfw and has_xml):\n",
    "            issues.append(stem)\n",
    "\n",
    "    if not issues:\n",
    "        print(\"All image files have corresponding annotation files.\")\n",
    "    else:\n",
    "        print(\"Some files are missing corresponding pairs.\")"
   ]
  }
 ]
}
